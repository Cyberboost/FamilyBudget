# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# -----------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/familybudget?schema=public"

# -----------------------------------------------------------------
# Clerk Auth  (https://clerk.com)
# -----------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# -----------------------------------------------------------------
# Plaid (https://plaid.com)
# -----------------------------------------------------------------
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox           # sandbox | development | production

# -----------------------------------------------------------------
# Encryption key for Plaid access tokens at rest (32 bytes hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------
ENCRYPTION_KEY=replace_with_64_char_hex_string

# -----------------------------------------------------------------
# App URL
# -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------
# Upstash Redis (for rate limiting)
# Provide UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN
# or leave blank to use an in-memory fallback (development only)
# -----------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
